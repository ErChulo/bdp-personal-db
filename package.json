{
  "name": "bdp",
  "private": true,
  "version": "0.1.0",
  "description": "BDP - Personal Database Management System (client-side)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/inline-dist.mjs && node scripts/verify-dist.mjs",
    "preview": "vite preview",
    "serve": "node scripts/serve-dist.mjs",
    "test:browser": "node scripts/test-browser.mjs",
    "test:browser:smoke": "node scripts/test-browser.mjs",
    "test:browser:e2e": "playwright test",
    "test:browser:e2e:ui": "playwright test --ui",
    "security:sql-injection": "npm run build && node scripts/sql-injection-check.mjs",
    "security:privacy": "npm run build && node scripts/privacy-audit.mjs",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "fflate": "^0.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.14.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.2.0",
    "vitest": "^2.1.0"
  }
}
